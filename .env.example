# Copy this file to .env on the server only.
# Never upload .env to GitHub.

ATV_API_MASTER_KEY=replace_with_long_random_secret

NOMBA_CLIENT_ID=replace_with_nomba_client_id
NOMBA_CLIENT_SECRET=replace_with_nomba_client_secret
NOMBA_ACCOUNT_ID=replace_with_nomba_account_id
NOMBA_BASE_URL=https://api.nomba.com

# Override these only if Nomba gives a different endpoint path in your dashboard/docs.
NOMBA_VERIFY_BANK_PATH=/v1/transfers/bank/lookup
NOMBA_VIRTUAL_ACCOUNT_PATH=/v1/accounts/virtual
NOMBA_PAYOUT_PATH=/v1/transfers/bank
NOMBA_TRANSACTION_STATUS_PATH=/v1/transactions/{id}
